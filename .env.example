# ShardDB — gas-fakes Drive integration environment
# Copy to .env and fill in values, then run: gas-fakes auth
# NEVER commit .env

# Required for real Drive tests
GCP_PROJECT_ID="your-gcp-project-id"

# Path to OAuth client credentials (download from GCP Console)
CLIENT_CREDENTIAL_FILE="private/oauth-credentials.json"

# Drive folder ID to create test files in during integration tests.
# Use a dedicated "ShardDB Tests" folder — the suite creates and deletes files there.
# Get the ID from the folder URL: drive.google.com/drive/folders/<ID>
SHARDDB_TEST_FOLDER_ID=""

# How many rows to insert in the Drive performance test (default: 50)
# Keep low to stay within Drive API quota; increase for deeper benchmarks.
SHARDDB_PERF_ROWS="50"

# Optional: suppress gas-fakes internal log noise
QUIET="true"
LOG_DESTINATION="CONSOLE"
